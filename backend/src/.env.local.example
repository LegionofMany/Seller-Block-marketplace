# ─────────────────────────────────────────────────────────────
# Zonycs Backend — Environment Variables
# Copy this file to .env (or set in Render dashboard).
# Lines marked REQUIRED will crash the app if missing.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────
# REQUIRED — Postgres connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Chain Configuration (choose ONE approach) ─────────────────
#
# OPTION A — Simple single-chain (Sepolia):
SEPOLIA_RPC_URL=
SEPOLIA_RPC_URL_FALLBACK=
CHAIN_KEY=base-sepolia
CHAIN_NAME=Base Sepolia
CHAIN_ID=84532
MARKETPLACE_REGISTRY_ADDRESS=0x578c8c9faB60776B50B9c6A8a8c7b9060c1dE390
MARKETPLACE_SETTLEMENT_V2_ADDRESS=
START_BLOCK=0
CHAIN_NATIVE_CURRENCY_SYMBOL=ETH
#
# OPTION B — Multi-chain JSON (overrides all OPTION A chain vars):
# CHAIN_CONFIG_JSON={"defaultChainKey":"base-sepolia","chains":[...]}

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for dev only.
CORS_ORIGINS=http://localhost:3000,https://www.zonycs.com

# ── Auth / JWT ────────────────────────────────────────────────
# REQUIRED in production — change this to a long random secret!
AUTH_JWT_SECRET=change-me-to-a-long-random-secret-in-production
AUTH_TOKEN_TTL_SECONDS=28800
AUTH_NONCE_TTL_SECONDS=600

# ── Admin Access ──────────────────────────────────────────────
# Comma-separated email addresses with admin access
ADMIN_EMAILS=
# Comma-separated wallet addresses with admin access
ADMIN_WALLET_ADDRESSES=

# ── Indexer ───────────────────────────────────────────────────
INDEXER_ENABLED=true
INDEXER_POLL_MS=5000
INDEXER_CHUNK_SIZE=2000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Cache ─────────────────────────────────────────────────────
CACHE_TTL_MS=30000

# ── Moderation ───────────────────────────────────────────────
LISTING_AUTOHIDE_REPORTS_THRESHOLD=3

# ── Frontend App URL (for email links) ───────────────────────
FRONTEND_APP_URL=https://www.zonycs.com

# ── Email Notifications (Postmark) ───────────────────────────
# Get token at https://postmarkapp.com
POSTMARK_SERVER_TOKEN=
NOTIFICATION_EMAIL_FROM=noreply@zonycs.com
NOTIFICATIONS_SCAN_MS=60000

# ── IPFS / Pinata ─────────────────────────────────────────────
# Required for image uploads. Get at https://pinata.cloud
PINATA_JWT=
PINATA_GATEWAY_BASE_URL=https://gateway.pinata.cloud/ipfs

# ── Blockchain Relayer ────────────────────────────────────────
# Private key for gasless relayer (0x + 64 hex chars)
RELAYER_PRIVATE_KEY=

# ── Airdrop Funder ────────────────────────────────────────────
# Private key of the wallet that funds airdrops (0x + 64 hex chars)
# If not set, the /airdrop/claim endpoint returns a no-op success.
AIRDROP_FUNDER_PRIVATE_KEY=

# ── Stripe (homepage ad payments) ─────────────────────────────
STRIPE_SECRET_KEY=
PROMOTION_HOMEPAGE_PRICE_CENTS=4900
PROMOTION_HOMEPAGE_DURATION_DAYS=7
PROMOTION_HOMEPAGE_PRIORITY=180
PROMOTION_HOMEPAGE_PLACEMENT_SLOT=homepage-paid-primary
