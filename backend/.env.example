PORT=4000

# Required
SEPOLIA_RPC_URL=
# Optional backup RPC URL
SEPOLIA_RPC_URL_FALLBACK=https://rpc.sepolia.org
MARKETPLACE_REGISTRY_ADDRESS=0x578c8c9faB60776B50B9c6A8a8c7b9060c1dE390

# Database (Postgres)
# Example: postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Optional CORS (comma-separated list or *)
# Example: http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGINS=

# Indexer / cache / API limits
INDEXER_ENABLED=true
START_BLOCK=0
INDEXER_POLL_MS=5000
INDEXER_CHUNK_SIZE=2000
CACHE_TTL_MS=30000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LISTING_AUTOHIDE_REPORTS_THRESHOLD=3

# Auth (Phase 2)
# Use a strong random value in production / Render.
AUTH_JWT_SECRET=
AUTH_TOKEN_TTL_SECONDS=28800
AUTH_NONCE_TTL_SECONDS=600

# Optional IPFS / Pinata uploads
PINATA_JWT=
PINATA_GATEWAY_BASE_URL=https://gateway.pinata.cloud

# Logging
NODE_ENV=development
LOG_LEVEL=debug